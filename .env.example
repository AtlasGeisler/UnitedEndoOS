# Copy to .env and fill in. .env is gitignored and must never be committed.
#
# When ANTHROPIC_API_KEY is set, the AI features (SOAP drafts, referral reports,
# image analysis, narratives) use Claude (claude-opus-4-8) instead of the offline
# mock. PHI is redacted before every call regardless of provider.

ANTHROPIC_API_KEY=

# Optional alternative. Used only if ANTHROPIC_API_KEY is not set.
# OPENAI_API_KEY=

# Optional. Overrides the session cookie secret in production.
# SESSION_SECRET=
